  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "L'ensemble de l'\xE9quipe du film pour leur engagement, leur g\xE9n\xE9rosit\xE9,
    leur patience et leur cr\xE9ativit\xE9.\r\nNotre formidable communaut\xE9 YouTube
    aussi fid\xE8le qu'un poireau \xE0 huitre.\r\nLaurent, Benoit et l'\xE9quipe
    Topito pour leur accueil et leurs posts-it.\r\nCyrien lov pour sa g\xE9n\xE9rosit\xE9
    et sa fid\xE9lit\xE9 ainsi qu'Aur\xE9lie Dunand et Valentine de P\xE9riple Prod.\r\nLa
    famille ERNOULT pour leur accueil incomparable.\r\nCharlotte HONINCKK et Julien
    GIRBIG\r\nPhilippe du Cigare \xE0 Moustache.\r\nL'inn\xE9rable Max BLANC\r\nBenjamin
    BUSNEL\r\n\r\nNos pr\xE9cieuses familles...\r\nEt tout particuli\xE8rement Sarah,
    Paul, Samantha, Mah\xE9 et \xC9l\xE9a"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
